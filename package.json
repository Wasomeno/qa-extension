{
  "name": "flowg-extension",
  "version": "1.0.1",
  "description": "Browser extension for Flowg",
  "main": "dist/chrome/background.js",
  "scripts": {
    "dev": "rspack --mode development --watch --env browser=chrome",
    "dev:firefox": "rspack --mode development --watch --env browser=firefox",
    "dev:hot": "npm run check-deps || npm run install-dev-deps && npm run check-deps && concurrently \"npm run dev\" \"npm run hot-reload\"",
    "install-dev-deps": "node scripts/install-dev-deps.js",
    "hot-reload": "node scripts/dev-reload.js",
    "check-deps": "node -e \"try { require('chokidar'); require('ws'); require('concurrently'); } catch(e) { console.error('❌ Hot reload dependencies missing. Installing...'); process.exit(1); }\"",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "rspack --mode production --env browser=chrome",
    "build:firefox": "rspack --mode production --env browser=firefox",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.998.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@reduxjs/toolkit": "^1.9.7",
    "@tanstack/react-query": "^5.8.1",
    "@tiptap/extension-image": "^2.26.1",
    "@tiptap/extension-link": "^2.3.1",
    "@tiptap/extension-placeholder": "^2.3.1",
    "@tiptap/extension-table": "^2.27.1",
    "@tiptap/extension-table-cell": "^2.27.1",
    "@tiptap/extension-table-header": "^2.27.1",
    "@tiptap/extension-table-row": "^2.27.1",
    "@tiptap/react": "^2.3.1",
    "@tiptap/starter-kit": "^2.3.1",
    "axios": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^10.16.4",
    "gitlab": "^14.2.2",
    "lucide-react": "^0.535.0",
    "markdown-it": "^13.0.1",
    "markdown-it-task-lists": "^2.1.1",
    "next-themes": "^0.4.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.61.1",
    "react-icons": "^4.11.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^8.1.3",
    "react-toastify": "^9.1.3",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tiptap-markdown": "^0.8.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@rspack/cli": "^1.7.0",
    "@rspack/core": "^1.7.0",
    "@tailwindcss/forms": "^0.5.6",
    "@testing-library/jest-dom": "^5.16.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.0",
    "@types/chrome": "^0.0.237",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.16",
    "buffer": "^6.0.3",
    "chokidar": "^3.5.3",
    "concurrently": "^8.2.2",
    "crypto-browserify": "^3.12.1",
    "css-loader": "^6.8.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.31",
    "postcss-loader": "^7.3.3",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "style-loader": "^3.3.0",
    "tailwindcss": "^3.3.5",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vm-browserify": "^1.1.2",
    "ws": "^8.14.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
